# Copy to .env and fill in your values.
ANTHROPIC_API_KEY=sk-ant-...

# Gmail inbox panel (read-only over IMAP). Leave blank to hide the inbox panel.
# GMAIL_APP_PASSWORD is a Google "app password" (https://myaccount.google.com/apppasswords),
# NOT your normal Gmail password. Requires 2-Step Verification enabled on the account.
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
CALENDAR_ICS_URL="https://calendar.google.com/calendar/ical/.../basic.ics"

# Spotify player on the globe (optional). App from https://developer.spotify.com/dashboard.
# Blank = a Spotify search link is shown instead of an embedded player.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Manual API credit balance (optional). Anthropic has no balance API; paste your
# current balance from console.anthropic.com and the dashboard subtracts tracked spend.
CLAUDE_API_BALANCE=

# GitHub panel (optional). A personal access token with repo + notifications read
# scope (https://github.com/settings/tokens). Blank = the GitHub panel is hidden.
GITHUB_TOKEN=
GITHUB_LOGIN=

# Greeting name + optional default weather location (else the browser asks for
# geolocation). Weather is keyless (Open-Meteo).
USER_NAME=Fabio
WEATHER_LAT=
WEATHER_LON=
WEATHER_LABEL=

# Optional overrides (defaults shown):
# MODEL=claude-haiku-4-5
# MAX_OUTPUT_TOKENS=600
# WEB_SEARCH_MAX_USES=2
# MAX_RUNS=50
# HISTORY_FEEDBACK=1
# IMAP_HOST=imap.gmail.com
# INBOX_FETCH_COUNT=8
